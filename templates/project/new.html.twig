{% extends 'base.html.twig' %}

{% block title %}Nouveau Projet{% endblock %}

{% block body %}
<div class="container">
    <h1>Créer un nouveau Brief</h1>
    
    <div class="card">
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button class="btn btn-success" type="submit" style="margin-top: 1rem;">Enregistrer le brief</button>
            <a href="{{ path('app_project_index') }}" class="btn btn-secondary" style="margin-left: 1rem; margin-top: 1rem;">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
